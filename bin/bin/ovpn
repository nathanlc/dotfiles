#!/usr/bin/env sh

config="${OVPN_CONFIG:-glooko_stockholm_vpn.ovpn}"

if [[ ( "$1" == "list" ) || ( "$1" == "l" ) ]]; then
	openvpn3 sessions-list
	exit 0
fi

if [[ ( "$1" == "stop" ) || ( "$1" == "down" ) || ( "$1" == "s" ) || ( "$1" == "d" ) ]]; then
	openvpn3 session-manage -c "${config}" --disconnect
	exit 0
fi

echo "Connecting to: ${config}"
openvpn3 session-start -c "${config}"

openvpn3 sessions-list
